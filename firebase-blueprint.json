{
  "entities": {
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "User messages sent through the portfolio website contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The sender's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The sender's email address"
        },
        "subject": {
          "type": "string",
          "description": "The subject/topic of the message"
        },
        "message": {
          "type": "string",
          "description": "The full text message contents"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when the message was sent"
        }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Saves contact form message submissions and logs them for developer administration"
    }
  }
}
